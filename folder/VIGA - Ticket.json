    {
      "parameters": {
        "jsCode": "// Recuperamos los datos del nodo Aggregate\nconst tickets = items[0].json.tickets_limpios || [];\n\n// LÓGICA DE NOMBRADO SEGURA:\n// 1. Intentamos tomar el ID del primer ticket.\n// 2. Si no hay tickets o falla, usamos la fecha y hora exacta (timestamp) para que sea único.\nlet batchId;\n\nif (tickets.length > 0 && tickets[0].ticket_id) {\n  batchId = tickets[0].ticket_id;\n} else {\n  // Genera un número único basado en el tiempo (ej: 1715629999)\n  batchId = \"backup_\" + Date.now();\n}\n\n// Convertimos a JSON\nconst jsonString = JSON.stringify(tickets, null, 2);\nconst finalFileName = `tickets_lote_${batchId}.json`;\n\nreturn {\n  json: {\n    // Estas variables van al flujo\n    last_batch_id: (tickets.length > 0 && tickets[0].ticket_id) ? tickets[0].ticket_id : 0, \n    fileName: finalFileName,\n    cantidad_tickets: tickets.length\n  },\n  binary: {\n    data: {\n      data: Buffer.from(jsonString).toString('base64'),\n      mimeType: 'application/json',\n      fileName: finalFileName\n    }\n  }\n};"
      },
