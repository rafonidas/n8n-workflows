      "parameters": {
        "jsCode": "const startId = $input.first().json.next_start_id;\nconst batchSize = 1000;\nconst newItems = [];\n\nfor (let i = 0; i < batchSize; i++) {\n  const currentId = startId - i;\n  if (currentId > 0) {\n    newItems.push({\n      json: { \n        id: currentId,\n        batch_start_reference: startId \n      }\n    });\n  }\n}\nreturn newItems;"
      },
