    {
      "parameters": {
        "jsCode": "// 1. Obtener el archivo binario.\n// Asegúrate de que el nombre del campo en el nodo anterior coincida.\n// En un Form Trigger suele llamarse 'data' o el nombre del campo del formulario (ej. 'file').\n// Si tu input binario se llama diferente, cambia 'data' por ese nombre.\nconst binaryData = $input.item.binary.data; // <--- VERIFICA ESTE NOMBRE\n\nif (!binaryData) {\n  throw new Error(\"No se encontró información binaria. Verifica el nombre del campo.\");\n}\n\n// 2. Convertir el binario (Base64) a texto y luego a objeto JSON\nconst jsonString = Buffer.from(binaryData.data, 'base64').toString('utf8');\nconst tickets = JSON.parse(jsonString);\n\n// Verificamos que sea un array\nif (!Array.isArray(tickets)) {\n  throw new Error(\"El archivo JSON no contiene un array de tickets.\");\n}\n\n// 3. Devolver los tickets como ítems individuales\n// Esto \"explota\" el array: si entran 1 archivo, salen 8000 ítems\nreturn tickets.map(ticket => {\n  // Lógica de metadatos que ya tenías\n  const fileName = binaryData.fileName || \"unknown.json\";\n  const type = fileName.toLowerCase().includes(\"manual\") ? \"manual\" : \"ticket\";\n\n  return {\n    json: {\n      ...ticket, // Mantiene todas las propiedades del ticket (id, asunto, etc.)\n      metadata: {\n        source: fileName,\n        type: type,\n        ingest_date: new Date().toISOString()\n      }\n    }\n  };\n});"
      },
