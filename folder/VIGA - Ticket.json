    {
      "parameters": {
        "jsCode": "function stripHtml(html) {\n  if (!html || typeof html !== 'string') return \"\";\n  return html.replace(/<[^>]*>?/gm, '').replace(/&nbsp;/g, ' ').replace(/\\s+/g, ' ').trim();\n}\n\nreturn items.map(item => {\n  const ticket = item.json;\n  const problemaInicial = stripHtml(ticket.additionalDescription || ticket.description);\n  const rawComments = (ticket.ticketComments || []).sort((a, b) => new Date(a.createdAt) - new Date(b.createdAt));\n  const validComments = rawComments.map(c => stripHtml(c.description)).filter(t => t.length > 2);\n  const solucion = validComments.length > 0 ? validComments[validComments.length - 1] : \"Sin solución\";\n  \n  return {\n    json: {\n      ticket_id: ticket.id,\n      titulo: (ticket.description || \"Sin título\").toString(),\n      problema_inicial: problemaInicial,\n      estado: ticket.ticketState?.name || \"Desconocido\",\n      cliente: ticket.client?.name || \"Interno\",\n      solucion_detectada: solucion,\n      _batch_start_reference: item.json.batch_start_reference\n    }\n  };\n});"
      },
