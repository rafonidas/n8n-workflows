    {
      "parameters": {
        "jsCode": "// Función auxiliar para limpiar HTML y espacios\nfunction stripHtml(html) {\n  if (!html || typeof html !== 'string') return \"\";\n  return html\n    .replace(/<[^>]*>?/gm, ' ') // Reemplaza tags por espacio para evitar palabras pegadas\n    .replace(/&nbsp;/g, ' ')\n    .replace(/\\s+/g, ' ') // Colapsa múltiples espacios en uno\n    .trim();\n}\n\nreturn items.map(item => {\n  const t = item.json;\n\n  // 1. Obtener y limpiar descripciones base\n  const asunto = stripHtml(t.description);\n  // A veces additionalDescription es null, usamos description como fallback\n  const problemaInicial = stripHtml(t.additionalDescription) || asunto;\n\n  // 2. Procesar Comentarios (La parte crítica)\n  let comentariosRaw = (t.ticketComments || [])\n    // Ordenar por fecha (del más viejo al más nuevo)\n    .sort((a, b) => new Date(a.createdAt) - new Date(b.createdAt))\n    // Limpiar texto\n    .map(c => stripHtml(c.description))\n    // Eliminar comentarios vacíos o muy cortos (menos de 3 letras, ej: \"Ok\")\n    .filter(text => text && text.length > 3);\n\n  // 3. Deduplicar comentarios consecutivos idénticos\n  // Esto soluciona el problema de \"se repite 3 veces el mismo mensaje\"\n  let comentariosUnicos = comentariosRaw.filter((texto, index, arr) => {\n    return index === 0 || texto !== arr[index - 1];\n  });\n\n  // 4. Limpiar redundancia del Problema vs Primer Comentario\n  // Si el primer comentario es igual al problema inicial, lo quitamos de la lista\n  if (comentariosUnicos.length > 0 && comentariosUnicos[0] === problemaInicial) {\n    comentariosUnicos.shift(); \n  }\n\n  // 5. Separar Solución vs Conversación\n  // Asumimos que el ÚLTIMO mensaje es la solución o el cierre del ticket.\n  let solucion = \"No se registró una solución explícita en los comentarios.\";\n  let historialConversacion = [];\n\n  if (comentariosUnicos.length > 0) {\n    solucion = comentariosUnicos.pop(); // Sacamos el último elemento y lo guardamos como solución\n    historialConversacion = comentariosUnicos; // El resto queda como historia\n  }\n\n  // 6. Construir Metadata (Para filtros estrictos)\n  const metadata = {\n    ticket_id: t.id,\n    fecha_creacion: t.createdAt, // Importante para saber si es viejo o nuevo\n    cliente: t.client?.name || \"Desconocido\",\n    categoria: t.ticketClasification?.name || \"General\", // Usa la clasificación humana si existe\n    estado: t.ticketState?.name || \"Desconocido\",\n    url_ticket: `https://tu-sistema-tickets.com/ticket/${t.id}` // Opcional: útil para referencia\n  };\n\n  // 7. Construir el BLOQUE DE TEXTO FINAL (Content) para el Vector Store\n  // Este formato ayuda al LLM a distinguir qué es qué.\n  const contenidoVectorial = `\nTICKET ID: ${t.id}\nFECHA: ${t.createdAt}\nCATEGORÍA: ${metadata.categoria}\nCLIENTE: ${metadata.cliente}\n\nASUNTO:\n${asunto}\n\nDESCRIPCIÓN DEL PROBLEMA:\n${problemaInicial}\n\nHISTORIAL DE CONVERSACIÓN (Pasos intermedios):\n${historialConversacion.length > 0 ? historialConversacion.map(c => `- ${c}`).join('\\n') : \"Sin intercambio intermedio.\"}\n\nSOLUCIÓN TÉCNICA / RESOLUCIÓN FINAL:\n${solucion}\n`.trim();\n\n  // Devolver estructura compatible con Vector Store\n  return {\n    json: {\n      id: t.id,\n      content: contenidoVectorial, // Esto es lo que se incrusta (embedding)\n      metadata: metadata // Esto va a las columnas de metadatos (filtro)\n    }\n  };\n});"
      },
