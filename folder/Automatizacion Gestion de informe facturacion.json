    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "USE {{$json[\"db\"]}};\nSELECT  \n    DB_NAME() as dbname,\n\n    -- Normalización de Pais\n    CASE \n        WHEN RIGHT(DB_NAME(), LEN(DB_NAME()) - CHARINDEX('_', DB_NAME())) = 'CINES'\n            THEN 'AR'\n        ELSE RTRIM(\n            LEFT(\n                RIGHT(DB_NAME(), LEN(DB_NAME()) - CHARINDEX('_', DB_NAME())),\n                PATINDEX('%[0-9]%', RIGHT(DB_NAME(), LEN(DB_NAME()) - CHARINDEX('_', DB_NAME())) + '0') - 1\n            )\n        )\n    END AS Pais,\n\n    -- Normalización de Entorno\n    CASE \n        WHEN RIGHT(DB_NAME(), 1) LIKE '[0-9]' \n            THEN 'APP' + RIGHT(DB_NAME(), 1)\n        WHEN RIGHT(DB_NAME(), LEN(DB_NAME()) - CHARINDEX('_', DB_NAME())) = 'CINES' \n            THEN 'CINES'\n        ELSE 'APP'\n    END AS Entorno,\n\n    YEAR(T.Fecha) as anio,\n    MONTH(T.Fecha) as mes,\n    COUNT(C.CuitId) AS cantidad\nFROM Comprobante AS C WITH(NOLOCK)\nINNER JOIN rol  \n    ON C.CuitId = Rol.CuitId  \n   AND C.RolEmisorId = Rol.RolId  \n   AND Rol.TipoRol = 1\nINNER JOIN Transaccion AS T  \n    ON T.CuitId = C.CuitId  \n   AND T.TransaccionId = C.TransaccionId\nWHERE C.Resultado <> 'R'\n  AND YEAR(T.Fecha) = YEAR(DATEADD(MONTH, -1, GETDATE()))\n  AND MONTH(T.Fecha) = MONTH(DATEADD(MONTH, -1, GETDATE()))\nGROUP BY YEAR(T.Fecha), MONTH(T.Fecha)\nORDER BY Pais, Entorno, anio, mes;\n"
      },
