    {
      "parameters": {
        "jsCode": "const values = items.map(r => \n  `('${r.json.Pais}', '${r.json.Entorno}', ${r.json.anio}, ${r.json.mes}, ${r.json.cantidad})`\n).join(\",\\n\");\n\nreturn [{\n  json: {\n    query: `\n      INSERT INTO ValoresCOMFIAR (pais, entorno, anio, mes, cantidad)\n      VALUES ${values};\n    `\n  }\n}];\n"
      },
