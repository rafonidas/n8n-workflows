      "parameters": {
        "functionCode": "// Acceso al storage global del workflow\nconst sd = this.getWorkflowStaticData('global');\n\n// Reinicia el log al inicio de la ejecución si quieres que no se acumulen históricos\nif (!sd.logs) sd.logs = [];\n\n// Procesa los items que llegan\nitems.forEach(item => {\n  const json = item.json || {};\n  const ts = new Date().toISOString();\n\n  sd.logs.push({\n    ts,\n    db: json.dbname || 'N/A',\n    pais: json.Pais || 'N/A',\n    entorno: json.Entorno || 'N/A',\n    anio: json.anio || null,\n    mes: json.mes || null,\n    cantidad: json.cantidad ?? 0\n  });\n});\n\n// Devuelve los mismos items para que el flujo continúe\nreturn items;\n"
