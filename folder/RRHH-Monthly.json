    {
      "parameters": {
        "jsCode": "// Obtenemos todos los items de entrada\nconst items = $input.all();\n\n// 1. Verificamos si es el mensaje de \"No hay eventos\"\nif (items.length > 0 && items[0].json.hay_eventos === false) {\n\tconst mensajeVacio = `\n\t\t<div style=\"font-family: Arial, sans-serif; color: #555; padding: 20px; text-align: center; border: 1px solid #ddd; border-radius: 8px;\">\n\t\t\t<h3>📅 Próximo Mes</h3>\n\t\t\t<p>No hay cumpleaños ni aniversarios registrados para el mes entrante.</p>\n\t\t</div>\n\t`;\n\treturn [{ json: { html_email: mensajeVacio } }];\n}\n\n// 2. Si hay datos, los ordenamos por día (para que el email se vea ordenado cronológicamente)\n// Extraemos el día de la fecha \"2000-12-13\" -> 13\nitems.sort((a, b) => {\n\tconst diaA = parseInt(a.json.fecha_display.split('/')[2]);\n\tconst diaB = parseInt(b.json.fecha_display.split('/')[2]);\n\treturn diaA - diaB;\n});\n\n// 3. Construimos las filas de la tabla HTML\nlet filasHtml = '';\n\nfor (const item of items) {\n\tconst empleado = item.json;\n\t// const dia = empleado.fecha.split('-')[2]; // Ya no se usa solo el día\n\t\n\t// Definimos estilos/iconos según el tipo\n\tlet estiloBadge = '';\n\tlet icono = '';\n\t\n\tif (empleado.tipo === 'Cumpleaños') {\n\t\testiloBadge = 'background-color: #e3f2fd; color: #1565c0; border: 1px solid #bbdefb;'; // Azulito\n\t\ticono = '🎂';\n\t} else {\n\t\testiloBadge = 'background-color: #fff3e0; color: #e65100; border: 1px solid #ffe0b2;'; // Naranja\n\t\ticono = '🥇';\n\t}\n\n\tfilasHtml += `\n\t\t<tr style=\"border-bottom: 1px solid #eee;\">\n\t\t\t<td style=\"padding: 12px; text-align: center; font-weight: bold; color: #333;\">${empleado.mensaje_completo}</td>\n\t\t\t<td style=\"padding: 12px; color: #333;\">${empleado.nombre}</td>\n\t\t\t<td style=\"padding: 12px; text-align: center; color: #333;\">${empleado.country || 'N/A'}</td>\n\t\t\t<td style=\"padding: 12px; text-align: center;\">\n\t\t\t\t<span style=\"display: inline-block; padding: 4px 12px; border-radius: 12px; font-size: 12px; font-weight: bold; ${estiloBadge}\">\n\t\t\t\t\t${icono} ${empleado.tipo}\n\t\t\t\t</span>\n\t\t\t</td>\n\t\t</tr>\n\t`;\n}\n\n// 4. Armamos la estructura completa del HTML\nconst htmlFinal = `\n<div style=\"font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; max-width: 800px; margin: 0 auto; border: 1px solid #e0e0e0; border-radius: 8px; overflow: hidden;\">\n\t\n\t<div style=\"background-color: #4a90e2; color: white; padding: 20px; text-align: center;\">\n\t\t<h2 style=\"margin: 0; font-size: 24px;\">🎉 Celebraciones de Diciembre</h2>\n\t\t<p style=\"margin: 5px 0 0 0; opacity: 0.9; font-size: 14px;\">Fechas importantes del equipo</p>\n\t</div>\n\n\t<table style=\"width: 100%; border-collapse: collapse; background-color: white;\">\n\t\t<thead>\n\t\t\t<tr style=\"background-color: #f9f9f9; text-transform: uppercase; font-size: 12px; color: #666;\">\n\t\t\t\t<th style=\"padding: 12px; text-align: center; width: 100px;\">Fecha</th>\n\t\t\t\t<th style=\"padding: 12px; text-align: left;\">Colaborador</th>\n\t\t\t\t<th style=\"padding: 12px; text-align: center; width: 100px;\">País</th>\n\t\t\t\t<th style=\"padding: 12px; text-align: center; width: 120px;\">Celebración</th>\n\t\t\t</tr>\n\t\t</thead>\n\t\t<tbody>\n\t\t\t${filasHtml}\n\t\t</tbody>\n\t</table>\n\n\t<div style=\"background-color: #f5f5f5; padding: 10px; text-align: center; font-size: 11px; color: #888;\">\n\t\tReporte generado automáticamente por n8n\n\t</div>\n</div>\n`;\n\n// Devolvemos un solo item con el HTML listo para enviar\nreturn [{ json: { html_email: htmlFinal } }];"
      },
