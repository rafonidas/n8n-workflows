    {
      "parameters": {
        "content": "Se fijará la fecha de hoy, puede tomarla del Schedule Trigger y se fijará qué empleados cumplen Años o Aniversario dentro de la empresa en el mes entrante",
        "height": 336
      },
      "type": "n8n-nodes-base.stickyNote",
      "position": [
        352,
        -320
      ],
      "typeVersion": 1,
      "id": "0e17c62b-677f-4bc2-9a1a-2e729c42b407",
      "name": "Sticky Note2"
    },
    {
      "parameters": {
        "jsCode": "const now = new Date();\n\nconst getNextMonthName = () => new Date(new Date().setMonth(new Date().getMonth() + 1)).toLocaleString('es-ES', { month: 'long' }).replace(/^\\w/, c => c.toUpperCase());\n// targetMonth es el índice (0-11) del próximo mes.\nlet targetMonth = now.getMonth() + 1; \nif (targetMonth > 11) {\n    targetMonth = 0; // Si es Diciembre (11), el próximo es Enero (0)\n}\nconst targetMonthName = getNextMonthName();\nconst results = [];\n\n// Función para calcular la diferencia en años (edad o antigüedad)\nconst calculateDifferenceInYears = (eventDate) => {\n    if (!eventDate || isNaN(eventDate.getTime())) return 0;\n    \n    // Obtenemos el año en que el evento ocurrirá (actual o próximo año)\n    const nextEventYear = now.getFullYear() + (targetMonth > now.getMonth() ? 0 : 1);\n    \n    // Calculamos la diferencia simple de años\n    let diffYears = nextEventYear - eventDate.getFullYear();\n    \n    // Nota: Esta lógica asume que si el mes de la fecha registrada (eventDate)\n    // coincide con el targetMonth, la edad calculada por la diferencia de años será la correcta\n    // que tendrá en ese momento, ya que la ejecución está programada antes del evento.\n    // Esto funciona bien para la antigüedad o la edad en el momento del próximo cumpleaños.\n    \n    return diffYears;\n};\n\n// 2. Iterar sobre todos los empleados traidos del nodo anterior\nfor (const item of $input.all()) {\n    const row = item.json;\n\n    const nameField = 'Nombre'; \n    const birthdayDateField = 'BirthdayDate'; \n    const admissionDateField = 'AdmissionDate';\n    const countryField = 'Country'; // Asumiendo que el campo es 'Country'\n\n    const chequearFecha = (fechaString, tipoEvento) => {\n        if (!fechaString) return;\n        \n        const fecha = new Date(fechaString);\n        \n        // Verificar si la fecha es válida\n        if (isNaN(fecha.getTime())) return;\n\n        // Usamos getUTCMonth para evitar problemas de zona horaria con fechas ISO\n        // Comparamos el mes de la fecha guardada con el mes objetivo\n        // Nota: targetMonth es el índice JS (0-11) del próximo mes.\n        if (fecha.getUTCMonth() === targetMonth) {\n            \n            // 1. Calcular la diferencia en años (edad o antigüedad)\n            const diffAños = calculateDifferenceInYears(fecha);\n            const subject = 'años';\n            \n            // 2. Formato de fecha DD/MM/YYYY\n            const datePart = fecha.getUTCDate().toString().padStart(2, '0');\n            const monthPart = (fecha.getUTCMonth() + 1).toString().padStart(2, '0'); // +1 para mes 1-12\n            const yearPart = fecha.getUTCFullYear();\n            const fechaDisplay = `${datePart}/${monthPart}/${yearPart}`;\n\n            // 3. Icono\n            const icono = tipoEvento === 'Cumpleaños' ? '🎂' : '🥇';\n            \n            // 4. Mensaje Completo (Formato deseado: 02/01/1990 | 36 años Nataly Suarez Colombia 🎂 Cumpleaños)\n            const mensajeCompleto = `${fechaDisplay} | ${diffAños} ${subject}`;\n\n\n            results.push({\n                json: {\n                    month: targetMonthName,\n                    nombre: row[nameField],\n                    country: row[countryField] || '',\n                    tipo: tipoEvento,\n                    fecha_display: fechaDisplay, // Nuevo: DD/MM/YYYY (para uso futuro)\n                    fecha_sort_key: fecha.getUTCDate().toString().padStart(2, '0'), // Día (DD) para ordenar en el siguiente nodo\n                    edad_o_antiguedad: diffAños,\n                    mensaje_completo: mensajeCompleto // La cadena formateada final\n                }\n            });\n        }\n    };\n\n    // Chequear Cumpleaños\n    chequearFecha(row[birthdayDateField], 'Cumpleaños');\n\n    // Chequear Aniversario\n    chequearFecha(row[admissionDateField], 'Aniversario');\n}\n\nif (results.length === 0) {\n    return [\n        {\n            json: {\n                mensaje: \"No se encontraron cumpleaños ni aniversarios para el próximo mes.\",\n                hay_eventos: false, // Bandera para identificar que NO hay datos\n                mes_analizado: targetMonthName\n            }\n        }\n    ];\n}\n\nreturn results;"
      },
