    {
      "parameters": {
        "functionCode": "const scripts = [\n  `SELECT usuarioid, SUBSTRING(mail,1,CHARINDEX('@gmial.com', mail)-1)+'@gmail.com'\n   FROM usuario\n   WHERE mail LIKE '%@gmial.com'`,\n  `SELECT usuarioid, SUBSTRING(mail,1,CHARINDEX('@hotamil.com', mail)-1)+'@hotmail.com'\n   FROM usuario\n   WHERE mail LIKE '%@hotamil.com'`,\n  `SELECT usuarioid, SUBSTRING(mail,1,CHARINDEX('@hotmaill.com', mail)-1)+'@hotmail.com'\n   FROM usuario\n   WHERE mail LIKE '%@hotmaill.com'`,\n  `SELECT usuarioid, SUBSTRING(mail,1,CHARINDEX('@hotmal.com', mail)-1)+'@hotmail.com'\n   FROM usuario\n   WHERE mail LIKE '%@hotmal.com'`,\n  `SELECT usuarioid, SUBSTRING(mail,1,CHARINDEX('@homail.com', mail)-1)+'@hotmail.com'\n   FROM usuario\n   WHERE mail LIKE '%@homail.com'`,\n  `SELECT * \n   FROM usuario\n   WHERE mail LIKE '%sincorreo%'\n     AND Eliminado != 1\n     AND PublicacionComprobantes != 0`,\n  `SELECT mail, LTRIM(RTRIM(REPLACE(mail,CHAR(9), '')))\n   FROM usuario\n   WHERE mail LIKE '% %'`\n];\nreturn scripts.map(s => ({ json: { script: s } }));"
      },
