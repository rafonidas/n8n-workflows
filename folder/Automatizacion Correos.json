      "parameters": {
        "functionCode": "const staticData = this.getWorkflowStaticData('global');\n\nconst totalFilas = items.length;\nconst script = $json[\"script\"] ?? 'Desconocido';\nconst timestamp = new Date().toISOString();\n\nconst mensaje = `[${timestamp}] Script: ${script} → ${totalFilas} filas`;\n\nif (!staticData.logs) {\n  staticData.logs = [];\n}\nstaticData.logs.push(mensaje);\n\n// Devolver tanto el mensaje actual como todo el acumulado\nreturn [{\n  json: {\n    log: mensaje,\n    acumulado: staticData.logs\n  }\n}];\n\n"
