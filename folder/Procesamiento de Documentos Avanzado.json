        "jsCode": "const llmResponse = $json.output || '{}';\nlet parsed;\ntry {\n  let cleanJson = llmResponse.replace(/```json/g, '').replace(/```/g, '');\n  parsed = JSON.parse(cleanJson);\n} catch (e) {\n  parsed = { resumen_ejecutivo: 'Error parsing JSON' };\n}\nreturn {\n  docId: $('9. Validar Extensión').item.json.docId,\n  fileName: $('9. Validar Extensión').item.json.fileName,\n  fecha_documento: parsed.fecha_documento || '',\n  empresas_identificadas: Array.isArray(parsed.empresas_identificadas) ? parsed.empresas_identificadas.join(', ') : '',\n  resumen_ejecutivo: parsed.resumen_ejecutivo || '',\n  documentText: $('11. Extraer Texto').item.json.text\n};"
