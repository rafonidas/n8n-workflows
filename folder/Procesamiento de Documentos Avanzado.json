        "jsCode": "const id = $input.item.json.docId;\nlet group1 = Math.floor(id / 10000) * 10000;\nlet folder1 = group1.toString().padStart(6, '0');\nlet remainder = id % 10000;\nlet group2 = Math.floor(remainder / 100) * 100;\nlet folder2 = group2.toString();\n\nlet searchPath = `/data/afm_docs/files/000000000/${folder1}/${folder2}/`;\n\nreturn {\n  json: {\n    docId: id,\n    searchPath: searchPath,\n    filePattern: `${id}-*-0.*.zip`\n  }\n};"
