    {
      "parameters": {
        "jsCode": "const { matches, env, dateSuffix } = $json;\n\nconst validos = matches.filter(r => r.version !== null && r.version !== undefined);\n\nif (validos.length === 0) {\n  return { json: { ...$json, sqlQuery: null } };\n}\n\nconst valuesList = validos\n  .map(r => `        ('${r.nombreRpt.replace(/'/g, \"''\")}', ${r.version})`)\n  .join(',\\n');\n\nconst sql =\n  `SELECT c.CuitId, c.RazonSocial, t.PuntoDeVentaId, t.TipoComprobanteId, ` +\n  `t.VersionRpt, t.NombreRpt, a.FechaSubida, a.UsuarioId\\n` +\n  `FROM TipoComprobanteXPuntoDeVenta t\\n` +\n  `INNER JOIN VersionReporte a ON t.VersionRpt=a.VersionId AND t.NombreRpt=a.NombreRpt\\n` +\n  `INNER JOIN Cuit c ON t.CuitId = c.CuitId\\n` +\n  `INNER JOIN (VALUES\\n${valuesList})\\n` +\n  `v(NombreRpt, VersionId) ON a.NombreRpt=v.NombreRpt AND a.VersionId=v.VersionId\\n` +\n  `WHERE c.FechaBajaServicio IS NULL;`;\n\nreturn { json: { ...$json, sqlQuery: sql } };\n"
      },
