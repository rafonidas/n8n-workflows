      "parameters": {
        "jsCode": "// Filtra .rpt con peso > 100kb y agrega el entorno de origen\nconst ONE_HUNDRED_KB = 100 * 1024;\nconst envName = $('Loop Entornos').first().json.env;\n\nconst heavy = $input.all()\n  .filter(item => {\n    const f = item.json;\n    return f.type === '-' && f.name.toLowerCase().endsWith('.rpt') && f.size > ONE_HUNDRED_KB;\n  })\n  .sort((a, b) => a.json.modifyTime - b.json.modifyTime)\n  .map(item => ({\n    json: {\n      env: envName,\n      name: item.json.name,\n      sizeKb: Math.round(item.json.size / 1024),\n      date: new Date(item.json.modifyTime).toLocaleString('es-AR', { timeZone: 'America/Argentina/Buenos_Aires' })\n    }\n  }));\n\nreturn heavy;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        816,
        1008
      ],
      "id": "af6332ef-7bd0-4e76-b59f-c38bb7058ea8",
      "name": "Filtrar .rpt > 100kb"
    },
    {
      "parameters": {
        "jsCode": "// Agrupa todos los archivos pesados de todos los entornos\nconst all = $input.all();\nif (all.length === 0) return [];\n\nconst fileRows = all.map(item => {\n  const f = item.json;\n  return `<li>[${f.env}] <b>${f.name}</b> — ${f.sizeKb} KB — ${f.date}</li>`;\n}).join('');\n\nreturn [{ json: { count: all.length, fileRows } }];"
      },
