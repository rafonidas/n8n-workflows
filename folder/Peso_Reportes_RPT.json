    {
      "parameters": {
        "jsCode": "\nconst fileContent = $json.text;\nconst lines = fileContent.split('\\n');\nconst matches = [];\n\nfor (const line of lines) {\n  const trimmed = line.trim();\n  if (!trimmed) continue;\n\n  const spaceIdx = trimmed.indexOf(' ');\n  if (spaceIdx === -1) continue;\n\n  const kb = parseInt(trimmed.substring(0, spaceIdx), 10);\n  if (isNaN(kb) || kb <= 500) continue;\n\n  const path = trimmed.substring(spaceIdx + 1).trim();\n  const parts = path.split('\\\\');\n\n  // Requiere estructura con carpeta de versión: [..., nombre_carpeta, version, nombre.rpt]\n  if (parts.length < 7) continue;\n\n  const version = parseInt(parts[5], 10);\n  const nombreRpt = parts[6].trim();\n\n  // Versión debe ser entero positivo\n  if (isNaN(version) || version <= 0) continue;\n\n  // Solo archivos .rpt reales (sin sufijos extra como .rpt20210201 o .rptfb)\n  if (!nombreRpt.toLowerCase().endsWith('.rpt')) continue;\n\n  matches.push({ kb, version, nombreRpt });\n}\n\nreturn {\n  json: {\n    matches,\n    hasMatches: matches.length > 0\n  }\n};\n"
      },
