      "parameters": {
        "jsCode": "const sqlResults = $json.sqlResults;\nconst resultFileName = $('Credentials Loop').item.json.resultFileName;\n\nconst headers = ['CuitId','RazonSocial','PuntoDeVentaId','TipoComprobanteId','VersionRpt','NombreRpt','FechaSubida','UsuarioId'];\nconst rows = sqlResults.map(r =>\n  headers.map(h => `\"${(r[h] ?? '').toString().replace(/\"/g, '\"\"')}\"`).join(';')\n);\nconst csvContent = [headers.join(';'), ...rows].join('\\n');\n\nreturn [{\n  json: { ...$json },\n  binary: {\n    data: {\n      data: Buffer.from(csvContent, 'utf8').toString('base64'),\n      mimeType: 'text/csv',\n      fileExtension: 'csv',\n      fileName: resultFileName\n    }\n  }\n}];\n"
      },
