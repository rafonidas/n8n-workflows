ternal', port: 11434, database: 'comfiar_cr', user: 'usr_automatico', password: '1qaz2wsx3edc'\n  },\n  'EC':  {\n    name: 'Ecuador - APP',\n    spId: '01HWKKASTMHFO5ZNCYWZDZLMU2L6SUBHK7',\n    teamsId: '19:9b2cc90d29d3474bade3a60f407f56ca@thread.tacv2',\n    server_host: 'host.docker.internal', port: 11434, database: 'comfiar_ec', user: 'usr_automatico', password: '1qaz2wsx3edc'\n  },\n  'PE':  {\n    name: 'Peru - APP',\n    spId: '01HWKKASRH3EFVYY2HQFE2H5XLVBDR6HJO',\n    teamsId: '19:d5b204e433134ff5b1f7a90e51d76982@thread.tacv2',\n    server_host: 'host.docker.internal', port: 11434, database: 'comfiar_pe', user: 'usr_automatico', password: '1qaz2wsx3edc'\n  },\n\n  // Fallback\n  'DEFAULT': {\n    name: 'General',\n    spId: 'PON_AQUI_UN_ID_DEFAULT_SI_QUIERES',\n    teamsId: '19:e2644020e0de42b0b55da552614c8ea5@thread.tacv2',\n    server_host: '', port: null, database: '', user: '', password: ''\n  }\n};\n\n// 3) Cálculo de Fecha Dinámica\nconst date = new Date();\ndate.setMonth(date.getMonth());\n\nconst year = date.getFullYear();\nconst month = String(date.getMonth() + 1).padStart(2, '0');\nconst dateSuffix = `${year}${month}`; // Ej: 202602\n\nreturn environments.map(env => {\n  const config = channelMap[env] || channelMap['DEFAULT'];\n\n  return {\n    json: {\n      env,\n      dateSuffix,\n      fileName: `ListadoDeReportes_${env}_APP_${dateSuffix}.txt`,\n      fullPath: `/files_host/XML_Mails_error/${env}/ListadoDeReportes_${env}_APP_${dateSuffix}.txt`,\n      logPath: `/files_host/XML_Mails_error/Resultados/Log_Ausencias_${dateSuffix}.txt`,\n      resultFileName: `RPT_Mayor500KB_${env}_APP_${dateSuffix}.csv`,\n\n      // Datos maestros\n      folderName: config.name,\n      folderId: config.spId,\n      teamsChannelId: config.teamsId,\n\n      // Conexión SQL del ambiente (para validar tamaño de RPT en base)\n      server_host: config.server_host,\n      port: config.port,\n      database: config.database,\n      user: config.user,\n      password: config.password\n    }\n  };\n});"
