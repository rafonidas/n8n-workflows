    {
      "parameters": {
        "mode": "retrieve-as-tool",
        "toolName": "documents",
        "toolDescription": "\"Usa esta herramienta SOLO para preguntas conceptuales, funcionales o de resolución de errores (FAQs).\nEjemplos: '¿Qué significa este error?', '¿Cómo configurar el entorno APP?'.\nNo la uses para buscar IDs exactos o promedios numéricos. Si el usuario pregunta por una query por nombre (no por ID), busca aquí primero para encontrar su ID correspondiente.\"",
        "tableName": {
          "__rl": true,
