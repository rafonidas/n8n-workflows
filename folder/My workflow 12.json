      ],
      "id": "d31d8c1e-0b37-4a79-aac7-e432b3e1cfe0",
      "name": "Loop Over Items"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "-- 1. Habilitar la extensión de vectores\nCREATE EXTENSION IF NOT EXISTS vector;\n\n-- 2. Tabla de Metadatos (El índice de tus archivos)\nCREATE TABLE IF NOT EXISTS document_metadata (\n    id TEXT PRIMARY KEY, -- file_id de Google Drive\n    title TEXT,\n    url TEXT,\n    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),\n    schema TEXT -- Aquí n8n guardará: query, pais, entorno, etc.\n);\n\n-- 3. Tabla de Documentos (Para RAG / Búsqueda Semántica)\nCREATE TABLE IF NOT EXISTS documents (\n    id BIGSERIAL PRIMARY KEY,\n    content TEXT, -- Contenido del chunk\n    metadata JSONB, -- Referencia al file_id y otros\n    embedding VECTOR(768) -- Para OpenAI text-embedding-3-small\n);\n\n-- 4. Tabla de Filas (Para tus 25k métricas y análisis SQL)\nCREATE TABLE IF NOT EXISTS document_rows (\n    id SERIAL PRIMARY KEY,\n    dataset_id TEXT REFERENCES document_metadata(id) ON DELETE CASCADE,\n    row_data JSONB -- Aquí se guarda cada fila como {query: 51656, pais: \"AR\", ...}\n);\n\n-- 5. Función de búsqueda para el nodo de Vector Store de n8n\nCREATE OR REPLACE FUNCTION match_documents (\n  query_embedding VECTOR(1536),\n  match_count INT DEFAULT NULL,\n  filter JSONB DEFAULT '{}'\n) RETURNS TABLE (\n  id BIGINT,\n  content TEXT,\n  metadata JSONB,\n  similarity FLOAT\n)\nLANGUAGE plpgsql\nAS $$\n#variable_conflict use_column\nBEGIN\n  RETURN QUERY\n  SELECT\n    id,\n    content,\n    metadata,\n    1 - (documents.embedding <=> query_embedding) AS similarity\n  FROM documents\n  WHERE metadata @> filter\n  ORDER BY documents.embedding <=> query_embedding\n  LIMIT match_count;\nEND;\n$$;",
        "options": {}
      },
