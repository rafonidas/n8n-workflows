    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=SELECT n.email, n.fullName, u.rrhh, COUNT(*) as notif_count\nFROM dbo.NotiViga_notification_logs n\nLEFT JOIN dbo.NotiViga_userInfo u ON u.email = n.email\nWHERE n.status = 'SUCCESS'\n  AND n.notifiedAt >= DATEADD(day, -5, GETDATE())\nGROUP BY n.email, n.fullName, u.rrhh\nHAVING COUNT(*) >= 2"
      },
