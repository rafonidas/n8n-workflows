    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nif (items.length === 0) return [];\n\nconst today = DateTime.now().setZone('America/Argentina/Buenos_Aires').toFormat('dd/MM/yyyy');\n\nconst rows = items.map(item => {\n  const { fullName, email, notif_count, rrhh } = item.json;\n  return `<tr>\n    <td style=\"padding:6px 12px;border-bottom:1px solid #e0e0e0;\">${fullName}</td>\n    <td style=\"padding:6px 12px;border-bottom:1px solid #e0e0e0;\">${email}</td>\n    <td style=\"padding:6px 12px;border-bottom:1px solid #e0e0e0;text-align:center;font-weight:bold;color:#c0392b;\">${notif_count}</td>\n    <td style=\"padding:6px 12px;border-bottom:1px solid #e0e0e0;\">${rrhh || 'No asignado'}</td>\n  </tr>`;\n}).join('');\n\nconst html = `<p>⚠️ <strong>Escalamiento Nivel 2 — Viga Time Report</strong> (${today})</p>\n<p>Los siguientes empleados recibieron <strong>3 o más notificaciones</strong> en los últimos 5 días:</p>\n<table style=\"border-collapse:collapse;width:100%;\">\n  <thead>\n    <tr style=\"background:#f5f5f5;\">\n      <th style=\"padding:6px 12px;text-align:left;\">Nombre</th>\n      <th style=\"padding:6px 12px;text-align:left;\">Email</th>\n      <th style=\"padding:6px 12px;text-align:center;\">Notificaciones</th>\n      <th style=\"padding:6px 12px;text-align:left;\">RRHH</th>\n    </tr>\n  </thead>\n  <tbody>${rows}</tbody>\n</table>\n<p style=\"color:#666;font-size:12px;\">Total: ${items.length} empleado${items.length > 1 ? 's' : ''} para revisión.</p>`;\n\nreturn [{ json: { message: html, count: items.length } }];\n"
      },
