      ],
      "notes": "Busca tickets de Colombia (countryId: 3).\nAJUSTAR: el endpoint real de busqueda y el countryId de Colombia.\nSi la API no soporta filtro por pais, buscar todos y filtrar en el codigo.\nTambien ajustar donde viene el token: Login VIGA -> json.token o json.data.token etc."
    },
    {
      "parameters": {
        "jsCode": "// ============================================\n// DETECTAR NUEVOS IDs DE COLOMBIA\n// ============================================\n// 1. Toma todos los tickets de la respuesta\n// 2. Filtra solo Colombia (doble check)\n// 3. Detecta IDs mayores al ultimo guardado\n// 4. Actualiza lastId en staticData\n// 5. Retorna solo los nuevos para guardar en Sheets\n\nconst staticData = $getWorkflowStaticData('global');\nconst lastId = staticData.lastId || 0;\n\n// --- Extraer tickets de la respuesta ---\nconst response = $input.first().json;\n\n// Intentar varias rutas posibles de la respuesta\nlet tickets = [];\nif (Array.isArray(response)) {\n  tickets = response;\n} else if (response.data && Array.isArray(response.data)) {\n  tickets = response.data;\n} else if (response.items && Array.isArray(response.items)) {\n  tickets = response.items;\n} else if (response.result && Array.isArray(response.result)) {\n  tickets = response.result;\n} else {\n  // Si es un solo objeto (como el GET /api/ticket/46000 del flujo original)\n  tickets = [response];\n}\n\nconsole.log(`Total tickets en respuesta: ${tickets.length}`);\nconsole.log(`Ultimo ID conocido: ${lastId}`);\n\n// --- Filtrar: nuevos + Colombia ---\nconst newColombiaTickets = [];\nlet maxId = lastId;\n\nfor (const ticket of tickets) {\n  const ticketId = ticket.id;\n  if (!ticketId) continue;\n  \n  // Registrar el ID mas alto que vimos\n  if (ticketId > maxId) maxId = ticketId;\n  \n  // Solo procesar IDs nuevos\n  if (ticketId <= lastId) continue;\n  \n  // --- Extraer pais (multiples rutas posibles) ---\n  let countryName = '';\n  let clientName = '';\n  \n  if (ticket.client?.country?.name) {\n    countryName = ticket.client.country.name;\n    clientName = ticket.client.name || '';\n  } else if (ticket.countryName) {\n    countryName = ticket.countryName;\n    clientName = ticket.clientName || '';\n  } else if (ticket.ticketSurveys?.[0]?.ticket?.client?.country?.name) {\n    countryName = ticket.ticketSurveys[0].ticket.client.country.name;\n    clientName = ticket.ticketSurveys[0].ticket.client?.name || '';\n  }\n  \n  // --- Solo Colombia ---\n  if (countryName !== 'Colombia') {\n    console.log(`Ticket #${ticketId} descartado - pais: '${countryName}'`);\n    continue;\n  }\n  \n  // --- Formatear fecha ---\n  let fechaFormateada = ticket.createdAt || '';\n  try {\n    const d = new Date(ticket.createdAt);\n    fechaFormateada = d.toLocaleString('es-CO', {\n      timeZone: 'America/Bogota',\n      year: 'numeric', month: '2-digit', day: '2-digit',\n      hour: '2-digit', minute: '2-digit'\n    });\n  } catch(e) {}\n  \n  console.log(`✅ Nuevo ticket Colombia: #${ticketId} - ${ticket.description}`);\n  \n  newColombiaTickets.push({\n    json: {\n      ticketId: ticketId,\n      description: ticket.description || '',\n      clientName: clientName,\n      country: countryName,\n      createdAt: fechaFormateada,\n      detectedAt: new Date().toISOString()\n    }\n  });\n}\n\n// --- Actualizar el ultimo ID visto ---\n// Solo avanzar si vimos IDs nuevos (cualquier pais)\nif (maxId > lastId) {\n  console.log(`Actualizando lastId: ${lastId} -> ${maxId}`);\n  staticData.lastId = maxId;\n}\n\nconsole.log(`Tickets nuevos de Colombia: ${newColombiaTickets.length}`);\n\n// Si retorna [] el flujo se detiene antes de Sheets\nreturn newColombiaTickets;"
      },
      "id": "57c68399-4ac4-47c4-9099-fa7ae3d0c38f",
      "name": "Detect New Colombia IDs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        832,
        1264
      ],
      "notes": "Logica central:\n- Compara IDs contra staticData.lastId\n- Filtra solo Colombia\n- Actualiza lastId al maximo visto\n- Retorna [] si no hay nuevos (flujo se detiene)\n- Logs en consola para debugging"
    },
