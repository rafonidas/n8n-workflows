      "id": "eec15166-4a7c-4da9-bfc4-73e49759ea87",
      "name": "Schedule Saturday",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        -224,
        80
      ],
      "notes": "Cron: cada 30 min, de 7am a 10pm, SOLO sabados (dia 6).\nNo se ejecuta de lunes a viernes = cero consumo entre semana.\nAjustar horario segun necesidad."
    },
    {
      "parameters": {
        "jsCode": "// ============================================\n// INIT TRACKING - Gestion de estado persistente\n// ============================================\n// Usa staticData para recordar entre ejecuciones:\n// - lastChecked: ultimo momento revisado\n// - notifiedIds: IDs ya notificados (evita duplicados)\n// - lastSaturdayDate: para resetear al iniciar nuevo sabado\n\nconst staticData = $getWorkflowStaticData('global');\nconst now = new Date();\nconst todayStr = now.toISOString().split('T')[0];\n\n// Si es un nuevo sabado (diferente al ultimo registrado), resetear tracking\nif (staticData.lastSaturdayDate !== todayStr) {\n  // Calcular viernes 18:00 como punto de inicio\n  const friday = new Date(now);\n  friday.setDate(now.getDate() - 1); // ayer = viernes\n  friday.setHours(18, 0, 0, 0);\n  \n  staticData.lastChecked = friday.toISOString();\n  staticData.notifiedIds = [];\n  staticData.lastSaturdayDate = todayStr;\n}\n\n// Fallback: si no hay datos previos\nif (!staticData.lastChecked) {\n  const friday = new Date(now);\n  friday.setDate(now.getDate() - 1);\n  friday.setHours(18, 0, 0, 0);\n  staticData.lastChecked = friday.toISOString();\n  staticData.notifiedIds = [];\n  staticData.lastSaturdayDate = todayStr;\n}\n\nreturn [{\n  json: {\n    lastChecked: staticData.lastChecked,\n    notifiedIds: staticData.notifiedIds,\n    checkTime: now.toISOString()\n  }\n}];"
      },
      "id": "8f556f7f-caf8-4193-bea6-403054539f8f",
      "name": "Init Tracking",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        0
      ],
      "notes": "Lee/inicializa el estado persistente.\nPrimer ciclo del sabado: referencia = viernes 18:00.\nCiclos siguientes: referencia = ultimo chequeo exitoso.\nReset automatico cada nuevo sabado."
    },
    {
