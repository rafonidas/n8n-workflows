    },
    {
      "parameters": {
        "jsCode": "// ============================================\n// FILTRAR, DEDUPLICAR Y FORMATEAR\n// ============================================\n// 1. Filtra solo clientes de Colombia\n// 2. Excluye tickets ya notificados (por ID)\n// 3. Formatea mensaje de WhatsApp\n// 4. Actualiza el tracking en staticData\n// Si no hay tickets nuevos, retorna [] y el flujo se detiene\n\nconst staticData = $getWorkflowStaticData('global');\nconst notifiedIds = staticData.notifiedIds || [];\nconst items = $input.all();\nconst newTickets = [];\n\nfor (const item of items) {\n  const ticket = item.json;\n  \n  // --- Extraer pais del cliente ---\n  // Ajustar la ruta segun la estructura real de respuesta del endpoint de busqueda\n  let countryName = '';\n  let clientName = '';\n  \n  // Ruta 1: respuesta tipo lista directa\n  if (ticket.client && ticket.client.country) {\n    countryName = ticket.client.country.name || '';\n    clientName = ticket.client.name || '';\n  }\n  // Ruta 2: respuesta con ticketSurveys (como en el ejemplo)\n  else if (ticket.ticketSurveys && ticket.ticketSurveys[0] && ticket.ticketSurveys[0].ticket) {\n    const innerTicket = ticket.ticketSurveys[0].ticket;\n    countryName = innerTicket.client?.country?.name || '';\n    clientName = innerTicket.client?.name || '';\n  }\n  \n  // --- Filtro: solo Colombia ---\n  if (countryName !== 'Colombia') continue;\n  \n  // --- Filtro: no repetir notificaciones ---\n  const ticketId = ticket.id;\n  if (notifiedIds.includes(ticketId)) continue;\n  \n  // --- Formatear fecha legible ---\n  const createdAt = ticket.createdAt || '';\n  let fechaFormateada = createdAt;\n  try {\n    const d = new Date(createdAt);\n    fechaFormateada = d.toLocaleString('es-CO', {\n      timeZone: 'America/Bogota',\n      year: 'numeric',\n      month: '2-digit',\n      day: '2-digit',\n      hour: '2-digit',\n      minute: '2-digit'\n    });\n  } catch(e) {}\n  \n  // --- Construir mensaje WhatsApp ---\n  const mensaje = [\n    `*Nuevo Ticket #${ticketId}*`,\n    `Asunto: ${ticket.description || 'Sin descripcion'}`,\n    `Cliente: ${clientName}`,\n    `Pais: ${countryName}`,\n    `Creado: ${fechaFormateada}`,\n    '',\n    '_Ticket creado fuera de horario laboral (Sabado)_'\n  ].join('\\n');\n  \n  newTickets.push({\n    json: {\n      ticketId: ticketId,\n      description: ticket.description,\n      createdAt: createdAt,\n      clientName: clientName,\n      country: countryName,\n      whatsappMessage: mensaje\n    }\n  });\n  \n  // Registrar como notificado\n  notifiedIds.push(ticketId);\n}\n\n// --- Actualizar tracking ---\nstaticData.notifiedIds = notifiedIds;\nstaticData.lastChecked = new Date().toISOString();\n\n// Si no hay tickets nuevos, retornar vacio = flujo se detiene aqui\n// Si hay, pasan al nodo de WhatsApp\nreturn newTickets;"
      },
      "id": "ba307b81-c04d-43f5-ae33-49a7c9cb7137",
