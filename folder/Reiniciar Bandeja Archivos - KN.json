    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json).filter(r => r && r.timestamp);\nconst cfg = $('Resolver Config').item.json;\nconst COOLDOWN_H = 4;\nconst mismo = rows.filter(r => r.entorno === cfg.entorno && r.resultado === 'success');\nmismo.sort((a,b) => new Date(b.timestamp) - new Date(a.timestamp));\nconst last = mismo[0];\nlet enCooldown = false;\nif (last) enCooldown = (Date.now() - new Date(last.timestamp).getTime()) / 3600000 < COOLDOWN_H;\nreturn [{ json: { ...cfg, enCooldown, ultimoReinicio: last ? last.timestamp : null } }];"
      },
