    {
      "parameters": {
        "jsCode": "const cfg = $('Resolver Config').item.json;\nconst http = $input.first().json;\nconst raw = typeof http.data === 'string' ? http.data : JSON.stringify(http.data || http);\nconst fault = /soap:Fault|Exception|<faultstring>/i.test(raw);\nconst errored = !!http.error || fault;\nreturn [{ json: {\n  timestamp: new Date().toISOString(),\n  entorno: cfg.entorno,\n  bandejaId: cfg.bandejaId,\n  motivo: cfg.motivo || '',\n  archivos_count: cfg.archivos_count != null ? cfg.archivos_count : null,\n  ws_status: errored ? 'fail' : 'success',\n  ws_response_raw: String(raw).slice(0, 2000),\n  resultado: errored ? 'fail' : 'success'\n}}];"
      },
