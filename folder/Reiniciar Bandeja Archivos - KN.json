    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst { messageType, country, errorMsg, errorTimestamp } = input;\n\n// 1. Definimos un diccionario de zonas horarias por país\nconst timezones = {\n  'ARG': 'America/Argentina/Buenos_Aires',\n  'ECU': 'America/Guayaquil',\n  'PER': 'America/Lima'\n};\n\n// 2. Buscamos la zona horaria del país. \n// Si country viene vacío o no está en la lista, el || asegura que use Argentina por defecto.\nconst selectedTimeZone = timezones[country] || 'America/Argentina/Buenos_Aires';\n\nconst time = new Date(errorTimestamp).toLocaleString('es-AR', {\n  timeZone: selectedTimeZone,\n  year: 'numeric',\n  month: '2-digit',\n  day: '2-digit',\n  hour: '2-digit',\n  minute: '2-digit'\n});\n\nlet text = '';\n\n// 3. Formateo de la salida en HTML usando <strong> y <br>\nif (messageType === 'success') {\n  text = `✅ <strong>Reinicio Exitoso</strong><br>País: ${country}<br>Hora: ${time}`;\n} else if (messageType === 'login_error') {\n  text = `❌ <strong>Error de Conexión</strong><br><strong>País:</strong> ${country}<br><strong>Error:</strong> ${errorMsg}<br><strong>Hora:</strong> ${time}`;\n} else if (messageType === 'restart_error') {\n  text = `⚠️ <strong>Falla al Reiniciar</strong><br><strong>País:</strong> ${country}<br><strong>Error:</strong> ${errorMsg}<br><strong>Hora:</strong> ${time}`;\n}\n\nreturn [{\n  json: {\n    text\n  }\n}];"
      },
