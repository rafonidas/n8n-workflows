        "jsCode": "const input = $input.first().json;\nconst entorno = input.entorno;\nconst cfg = {\n  \"APP ARG\": { url: \"https://app.comfiar.com.ar/WSCOMFIAR/WSComfiar.asmx\", user: \"WSN8N\", password: \"Vow&45\", bandejaId: \"30608517746\" },\n  \"APP PE\":  { url: \"https://app.comfiar.com.pe/ws/WSComfiar.asmx\",        user: \"WSN8N\", password: \"Oxs@612416\", bandejaId: \"20347845150\" },\n  \"TEST PE\": { url: \"https://test.comfiar.com.pe/ws/WSComfiar.asmx\",       user: \"WSN8N\", password: \"Oxs@612416\", bandejaId: \"20347845150\" },\n  \"APP EC\":  { url: \"https://app.comfiar.com.ec/wscomfiar/WSComfiar.asmx\", user: \"WSN8N\", password: \"Voy>87\", bandejaId: \"0991321764001\" }\n};\nconst c = cfg[entorno];\nif (!c) throw new Error(\"Entorno desconocido: \" + entorno);\nreturn [{ json: { ...input, ...c } }];"
