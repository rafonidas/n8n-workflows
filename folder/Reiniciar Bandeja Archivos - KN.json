    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nreturn [{\n  json: {\n    timestamp: input.timestamp,\n    entorno: input.country,\n    ws_status: input.messageType === 'success' ? 'success' : 'fail',\n    ws_response_raw: input.wsResponseRaw || '',\n    resultado: input.messageType === 'success' ? 'success' : 'fail'\n  }\n}];"
      },
