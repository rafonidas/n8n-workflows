        "jsCode": "// 1) Configuración de Ambientes\nconst environments = ['AR','BO','CO','CO2','CO3','CR','EC','PE'];\n\n// -------------------------------------------------------------\n// 2) MAPEO MAESTRO: ID SHAREPOINT + ID CANAL TEAMS\n// -------------------------------------------------------------\nconst channelMap = {\n  'AR':  { \n    name: 'Argentina - APP', \n    spId: '01HWKKASXFJOHNNKRITZFYVTXSOF2VZ6K7', \n    teamsId: '19:KqPHeI2vg9nNHO2de_AHbQGLK2Xh8Ah8iODV2ttJh_k1@thread.tacv2' \n  },\n  'BO':  { \n    name: 'Bolivia - APP',   \n    spId: '01HWKKAST2AVTCXU4QOJGY6FRPUOVAHIYF', \n    teamsId: '19:5e3bf46869f140a39d48f869795379c5@thread.tacv2' \n  },\n  'CO':  { \n    name: 'Colombia - APP',  \n    spId: '01HWKKASSEZYVFULZFWBCIGB7AACVTYK3N', \n    teamsId: '19:af378cf202564cfc87591f580cd70935@thread.tacv2' \n  },\n  'CO2': { \n    name: 'Colombia - APP2', \n    spId: '01HWKKASS3LKA6P44CT5BKZBRDBC6WOI7G', \n    teamsId: '19:d31a59baa80e47aba00f2944e684c4b3@thread.tacv2' \n  },\n  'CO3': { \n    name: 'Colombia - APP3', \n    spId: '01HWKKASRV2W4DJ4YQJFE3AOIBMQD3CBMT', \n    teamsId: '19:14b2fb9063904bccb047900af9ded2fe@thread.tacv2' \n  },\n  'CR':  { \n    name: 'Costa Rica - APP',\n    spId: '01HWKKASUFWHODOYG6TNAZANBKSP2EXIXC', \n    teamsId: '19:a9547625aaea4e02ae5b373bdc352ae9@thread.tacv2' \n  },\n  'EC':  { \n    name: 'Ecuador - APP',   \n    spId: '01HWKKASTMHFO5ZNCYWZDZLMU2L6SUBHK7', \n    teamsId: '19:9b2cc90d29d3474bade3a60f407f56ca@thread.tacv2' \n  },\n  'PE':  { \n    name: 'Peru - APP',      \n    spId: '01HWKKASRH3EFVYY2HQFE2H5XLVBDR6HJO', \n    teamsId: '19:d5b204e433134ff5b1f7a90e51d76982@thread.tacv2' \n  },\n  \n  // Fallback\n  'DEFAULT': { \n    name: 'General', \n    spId: 'PON_AQUI_UN_ID_DEFAULT_SI_QUIERES', \n    teamsId: '19:e2644020e0de42b0b55da552614c8ea5@thread.tacv2' \n  }\n};\n\n// 3) Cálculo de Fecha Dinámica\nconst date = new Date();\ndate.setMonth(date.getMonth()); \n\nconst year = date.getFullYear();\nconst month = String(date.getMonth() + 1).padStart(2, '0'); \nconst dateSuffix = `${year}${month}`; // Ej: 202602\n\nreturn environments.map(env => {\n  const config = channelMap[env] || channelMap['DEFAULT'];\n\n  return {\n    json: {\n      env,\n      dateSuffix,\n      fileName: `ListadoDeReportes_${env}_APP_${dateSuffix}.txt`,\n      fullPath: `/files_host/XML_Mails_error/${env}/ListadoDeReportes_${env}_APP_${dateSuffix}.txt`,\n      logPath: `/files_host/XML_Mails_error/Resultados/Log_Ausencias_${dateSuffix}.txt`,\n      \n      // Datos maestros\n      folderName: config.name,\n      folderId: config.spId,\n      teamsChannelId: config.teamsId\n    }\n  };\n});"
      },
