    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst { text, ...cfg } = item.json;\n\nconst lines = (text || '').split(/\\r?\\n/).filter(l => l.trim() !== '');\n\n// Formato esperado por línea (salida tipo Get-ChildItem | Select Length, FullName):\n// <KB> <ruta>\\\\<version>\\\\<nombre>.rpt\n// Ej: 992 D:\\\\COMFIAR_PE\\\\Directorios\\\\Reportes\\\\AFP-FA\\\\1\\\\AFP-FA.rpt\n// El encabezado (\"Tamaño(KB) FullName\") y la línea de guiones se descartan solos:\n// no matchean el regex porque no arrancan con un dígito.\nconst seen = new Set();\nconst matches = [];\n\nfor (const line of lines) {\n  const m = line.trim().match(/^(\\d+)\\s+(.+)$/);\n  if (!m) continue;\n\n  const kb = parseInt(m[1], 10);\n  if (kb <= 500) continue; // solo RPT > 500 KB\n\n  const parts = m[2].split('\\\\');\n  if (parts.length < 2) continue;\n\n  const version = parts[parts.length - 2];\n  const nombreRpt = parts[parts.length - 1];\n  const key = `${nombreRpt}|${version}`;\n\n  if (seen.has(key)) continue;\n  seen.add(key);\n\n  matches.push({ nombreRpt, version: parseInt(version, 10), kb });\n}\n\nreturn [{\n  json: {\n    ...cfg,\n    matches,\n    hasMatches: matches.length > 0\n  }\n}];"
      },
