    {
      "parameters": {
        "jsCode": "const sql = require('mssql');\n\nconst item = $input.first().json;\n\nconst valuesClause = item.matches\n  .map(m => `('${m.nombreRpt.replace(/'/g, \"''\")}', ${m.version})`)\n  .join(',\\n        ');\n\nconst query = `\nSELECT c.CuitId, c.RazonSocial, t.PuntoDeVentaId, t.TipoComprobanteId, t.VersionRpt, t.NombreRpt, a.FechaSubida, a.UsuarioId\nFROM TipoComprobanteXPuntoDeVenta t\nINNER JOIN VersionReporte a ON t.VersionRpt = a.VersionId AND t.NombreRpt = a.NombreRpt\nINNER JOIN Cuit c ON t.CuitId = c.CuitId\nINNER JOIN (VALUES\n        ${valuesClause}\n) v(NombreRpt, VersionId) ON a.NombreRpt = v.NombreRpt AND a.VersionId = v.VersionId\nWHERE c.FechaBajaServicio IS NULL;\n`;\n\nconst config = {\n  server: item.dbHost,\n  port: item.dbPort,\n  database: item.dbName,\n  user: item.dbUser,\n  password: item.dbPassword,\n  options: {\n    trustServerCertificate: true,\n    encrypt: false\n  }\n};\n\nlet results = [];\nconst pool = await sql.connect(config);\ntry {\n  const res = await pool.request().query(query);\n  results = res.recordset;\n} finally {\n  await pool.close();\n}\n\nreturn [{\n  json: {\n    ...item,\n    results,\n    hasResults: results.length > 0\n  }\n}];"
      },
