    {
      "parameters": {
        "jsCode": "// Calcula el nombre del archivo log del día anterior\nconst yesterday = new Date();\nyesterday.setDate(yesterday.getDate() - 1);\nconst y = yesterday.getFullYear();\nconst m = String(yesterday.getMonth() + 1).padStart(2, '0');\nconst d = String(yesterday.getDate()).padStart(2, '0');\nconst logFileName = `log_${y}${m}${d}.txt`;\n\nconst envs = $input.first().json.environments;\nreturn envs.map(e => ({ json: { ...e, logFileName } }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1040,
        176
      ],
      "id": "2fa0e753-c2c5-4ddd-a47b-16f6b93634ae",
      "name": "Calcular Nombre Log + Expandir"
    },
    {
      "parameters": {
        "options": {}
      },
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        -800,
        176
      ],
      "id": "cb7a5576-e49f-4190-be40-64db6ca72ee1",
      "name": "Loop Entornos"
    },
    {
      "parameters": {
        "operation": "list",
        "path": "/ServicioInformes/Log"
      },
      "type": "n8n-nodes-base.ftp",
      "typeVersion": 1,
      "position": [
        -576,
        -48
      ],
      "id": "46a4b81e-8024-46bc-a892-320a31ebd1d7",
      "name": "FTP - Listar Log Dir"
    },
    {
      "parameters": {
        "jsCode": "// Busca el log del día anterior y evalúa su estado\nconst envItem = $('Loop Entornos').first().json;\nconst logFileName = envItem.logFileName;\nconst env = envItem.env;\n\nconst files = $input.all().map(i => i.json);\nconst logFile = files.find(f => f.name === logFileName && f.type === '-');\n\nif (!logFile) {\n  return [{ json: { env, logFileName, error: true, reason: 'Archivo no encontrado' } }];\n}\n\nif (logFile.size === 0) {\n  return [{ json: { env, logFileName, error: true, reason: 'Archivo existe pero tiene peso = 0' } }];\n}\n\n// Si existe y tiene peso, necesitamos descargar para verificar contenido\nreturn [{ json: { env, logFileName, error: false, size: logFile.size, needsContentCheck: true } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -320,
        16
      ],
      "id": "ab79061c-9a45-43ef-93cd-5d597586339b",
      "name": "Verificar Existencia + Peso"
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.needsContentCheck }}",
              "value2": true
            }
          ]
        }
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        -80,
        16
      ],
      "id": "ed6489d1-2a9c-4ebe-acbc-bd314c474cbb",
      "name": "¿Necesita verificar contenido?"
    },
    {
      "parameters": {
        "path": "=/ServicioInformes/Log/{{ $json.logFileName }}",
        "options": {}
      },
      "type": "n8n-nodes-base.ftp",
      "typeVersion": 1,
      "position": [
        160,
        -64
      ],
      "id": "5405d7b8-d020-42de-9c41-99ff3e032cf1",
      "name": "FTP - Descargar Log"
    },
    {
      "parameters": {
        "jsCode": "// Lee el contenido del archivo descargado y busca la palabra 'error'\nconst meta = $('Verificar Existencia + Peso').first().json;\nconst binaryData = $input.first().binary;\n\nlet content = '';\nif (binaryData && binaryData.data) {\n  content = Buffer.from(binaryData.data.data, 'base64').toString('utf-8');\n}\n\nconst hasError = content.toLowerCase().includes('error');\n\nreturn [{\n  json: {\n    env: meta.env,\n    logFileName: meta.logFileName,\n    error: hasError,\n    reason: hasError ? 'El archivo contiene la palabra \"error\" en su contenido' : null,\n    size: meta.size\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        -64
      ],
      "id": "82e2d154-0bb4-469f-b12c-472a873cdeda",
      "name": "Verificar Contenido"
    },
    {
      "parameters": {
        "jsCode": "// Recibe todos los resultados (con error directo o tras verificar contenido)\n// y filtra solo los que tienen error\nconst all = $input.all();\nconst errores = all.filter(i => i.json.error);\n\nif (errores.length === 0) return [];\n\nconst rows = errores.map(i => {\n  const f = i.json;\n  return `<li>[${f.env}] <b>${f.logFileName}</b> — ${f.reason}</li>`;\n}).join('');\n\nreturn [{ json: { count: errores.length, rows } }];"
      },
