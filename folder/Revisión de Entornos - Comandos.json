    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\n// 1. Extraemos el contenido string directamente\nconst contentString = item.body?.content || '';\n\n// 2. Limpiamos las etiquetas HTML para dejar solo el comando (ej: \"/query 51748\")\nconst raw = contentString.replace(/<at>.*?<\\/at>/g, '').replace(/<[^>]+>/g, '').trim();\n\n// 3. Extraemos el channelId desde el @odata.context usando la regex probada\nlet channelId = '';\nconst contextUrl = item['@odata.context'] || '';\nconst channelMatch = contextUrl.match(/channels\\('([^']+)'\\)/);\n\nif (channelMatch && channelMatch[1]) {\n    // 4. Clave: Decodificar el string para transformar %3A en : y %40 en @\n    channelId = decodeURIComponent(channelMatch[1]);\n}\n\n// 5. Diccionario de países\nconst canalPais = {\n  '19:NohjVulNVM9XkmN1lG0Y4aRWueYhTX1eLWX66T-n83Y1@thread.tacv2': 'CO',\n  // Añadí el de tu JSON de prueba para que veas el match\n  '19:NQRQiHrUhszmot2VXKYb_bU_YEOJCW1DGq5vKLpnTpw1@thread.tacv2': 'AR' \n};\n\n// 6. Match del comando\nconst m = raw.match(/^\\/(\\w+)\\s*(.*)$/);\n\nreturn [{ \n  json: {\n    comando: m ? m[1].toLowerCase() : '',\n    arg: m ? m[2].trim() : '',\n    channelId: channelId,\n    pais_canal: canalPais[channelId] || null\n  }\n}];"
      },
