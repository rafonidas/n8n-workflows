        "jsCode": "const q = $json;\nif (!q.query_id) return [{ json: { reply: `No encontré la query ${$('Retry Split').first().json.retry_id}.`, _skip: true } }];\nconst app = (q.application || '').trim();\nconst flag = app === 'COMFIAR 2' ? 'comfiar2' : (app === 'VIGA' || app === 'Beelling') ? 'apgcore' : 'COMFIAR';\nreturn [{ json: { ...q,\n  flag,\n  country: $('Parse Command').first().json.pais_canal,\n  entorno: $('Retry Split').first().json.retry_entorno,\n  hora_ejecucion_real: DateTime.now().setZone('America/Argentina/Buenos_Aires').toFormat(\"yyyy-MM-dd'T'HH:mm:ss.SSS\"),\n  audit_startTime: new Date().getTime()\n}}];"
