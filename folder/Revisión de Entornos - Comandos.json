        "jsCode": "const b = $json.body ?? $json;\nconst raw = (b.text || '').replace(/<at>.*?<\\/at>/g,'').replace(/<[^>]+>/g,'').trim();\nconst channelId = b.conversation?.id || b.channelData?.channel?.id || '';\nconst canalPais = {\n  '19:NohjVulNVM9XkmN1lG0Y4aRWueYhTX1eLWX66T-n83Y1@thread.tacv2': 'CO'\n  // '<canal AR>':'AR','<canal BO>':'BO','<canal PE>':'PE'\n};\nconst m = raw.match(/^\\/(\\w+)\\s*(.*)$/);\nreturn [{ json: {\n  comando: m ? m[1].toLowerCase() : '',\n  arg: m ? m[2].trim() : '',\n  channelId,\n  pais_canal: canalPais[channelId] || null\n}}];"
