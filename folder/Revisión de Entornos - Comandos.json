    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\nconst scope = $('Parse Command').first().json.arg || $('Parse Command').first().json.pais_canal || 'TODOS';\nif (!rows.length) return [{ json: { reply: `No hay queries para ${scope}.` } }];\nconst grupos = {};\nfor (const r of rows) (grupos[r.type || 'sin-type'] ||= []).push(r.query_id);\nlet txt = `**Queries (${scope})**\\n`;\nfor (const [t, ids] of Object.entries(grupos)) txt += `\\n**${t} (${ids.length}):** ${ids.join(', ')}`;\nreturn [{ json: { reply: txt } }];"
      },
