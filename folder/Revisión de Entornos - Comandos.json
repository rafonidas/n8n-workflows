        "jsCode": "const rows = $input.all().map(i => i.json).filter(j => j.query_id);\nconst id = $('Parse Command').first().json.arg;\nif (!rows.length) return [{ json: { reply: `No encontré la query ${id}.` } }];\nlet txt = '';\nrows.forEach((r, i) => {\n  const tag = rows.length > 1 ? ` (variante ${i+1}/${rows.length})` : '';\n  txt += `**${r.query_id}${tag}** — ${r.description || ''}\\n\\n\\`\\`\\`sql\\n${r.revision_query}\\n\\`\\`\\`\\n\\n`;\n});\nreturn [{ json: { reply: txt.trim() } }];"
