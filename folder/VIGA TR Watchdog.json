    {
      "parameters": {
        "jsCode": "// ESTE NODO TIENE QUE , EN CASO DE HABER UNA LOG DE NOTEJECUCION DEL FLUJO EL DIA DE HOY, CORROBORAR SU ESTADO, DEVUELTO POR A MISTA QUERY DE ANTES, DECIDIRA EN BASE A 3 ESTADOS y A, SI ES POSIBLE, LA STATIC GLOBAL DATA O LA INFO AL MOMENTO DE LA EJECUCION,MPREFERENTEMENTE MEJORAR LA TABLA DE DATOS PARA AGREGAR ESTE VALOR, PERO ES NECESARIO SABER LA CANTIDAD DDE ERRORES, NOTIFICADOS, ETC, SALTEADOS. EN CASO DE TENER ESTADO EXXITO NO HACER NADA, PERO SI ES INCOMPLETO, OSEA QUE HUBO UN ERROR EN SQL TEAMS. HAY QUE REVISAR Y SABER A QUIENES SE NOTIFICÓ. LA IDEA ES TENER UNA VALIDACION EXTRA DE ESTADO QUE CUSTOMICE LA INFORMACION QUE SE VA A ENVIAR AL CANAL, SI SOLO FALTA 1 PERSONA, POODRIA HSTA DECIR EL NOMRE PARA Q LO HAGAN MANUUALMENTE LOGICA PARA CUSTOMIZAR EL MENSAJE SEGUN EL ESTADO PARA FACILITAR LA ACCION A TOMAR\nreturn $input.all();"
      },
