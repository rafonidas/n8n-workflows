      "parameters": {
        "content": "## Watchdog — VigaTimeReport\nSe ejecuta a las 11:00 AM todos los dias habiles.\nVerifica que haya al menos 1 registro en dbo.NotiViga_execution_logs del dia de hoy.\nSi no hay -> alerta a Teams.\nSi hay -> no hace nada.",
        "height": 212,
        "width": 380
      },
      "id": "41bab4fa-c4c2-4f8b-92d5-cc13eb863679",
      "name": "Note Watchdog",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        496,
        -736
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    status, \n    COUNT(*) as ran_today\nFROM dbo.NotiViga_execution_logs\nWHERE dateTime >= CAST(GETDATE() AS DATE)\n  AND dateTime < DATEADD(day, 1, CAST(GETDATE() AS DATE))\n  AND executionId = 2846\nGROUP BY status;"
      },
