      "id": "d6b36368-9756-4ce1-a672-ad372c2d22fb",
      "name": "Split In Batches",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        -1104,
        288
      ]
    },
    {
      "parameters": {
        "jsCode": "// Calcular ruta basada en lógica matemática del ID\nconst id = $json.documentId;\nconst basePath = $('Configurar Rango IDs').item.json.basePath;\n\n// Nivel 1: Math.floor(ID/10000)*10000\nconst level1 = Math.floor(id / 10000) * 10000;\nconst level1Formatted = String(level1).padStart(6, '0');\n\n// Nivel 2: ID % 10000 (últimos 4 dígitos)\nconst level2 = id % 10000;\nconst level2Formatted = String(level2);\n\n// Construir ruta del directorio\nconst dirPath = `${basePath}/${level1Formatted}/${level2Formatted}`;\n\n// Patrón de búsqueda: ${ID}-*-0.*.zip\nconst searchPattern = `${id}-*-0.*.zip`;\n\nreturn {\n  documentId: id,\n  dirPath: dirPath,\n  searchPattern: searchPattern,\n  fullSearchPath: `${dirPath}/${searchPattern}`\n};"
      },
      "id": "4cfafef8-def0-4b0e-b6f6-46c3ea5e0470",
      "name": "Calcular Ruta",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -896,
        384
      ]
    },
    {
      "parameters": {
        "jsCode": "// Buscar archivo ZIP que coincida con el patrón\nconst fs = require('fs');\nconst path = require('path');\n\nconst dirPath = $json.dirPath;\nconst documentId = $json.documentId;\n\n// Verificar si el directorio existe\nif (!fs.existsSync(dirPath)) {\n  return {\n    documentId: documentId,\n    fileExists: false,\n    filePath: null,\n    fileName: null,\n    extractedFileName: null\n  };\n}\n\n// Listar archivos y buscar coincidencia con patrón\nconst files = fs.readdirSync(dirPath);\nconst pattern = new RegExp(`^${documentId}-.*-0\\\\..*\\\\.zip$`);\nconst matchedFile = files.find(f => pattern.test(f));\n\nif (matchedFile) {\n  return {\n    documentId: documentId,\n    fileExists: true,\n    filePath: path.join(dirPath, matchedFile),\n    fileName: matchedFile,\n    extractedFileName: null\n  };\n} else {\n  return {\n    documentId: documentId,\n    fileExists: false,\n    filePath: null,\n    fileName: null,\n    extractedFileName: null\n  };\n}"
      },
      "id": "448281d9-edb6-4e35-aba7-ab651a6baf5b",
