        "jsCode": "// Preparar metadatos para los documentos\nconst documentId = $('Buscar Archivo ZIP').item.json.documentId;\nconst zipFileName = $('Buscar Archivo ZIP').item.json.fileName;\nconst extractedFile = $json.fileName || 'unknown';\n\n// Retornar datos binarios con metadatos inyectados\nreturn {\n  binary: $binary.data,\n  metadata: {\n    documentId: String(documentId),\n    zipFileName: zipFileName,\n    extractedFileName: extractedFile,\n    processedAt: new Date().toISOString(),\n    source: 'AFM_PRUEBAS'\n  }\n};"
