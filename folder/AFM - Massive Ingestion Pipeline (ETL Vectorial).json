    {
      "parameters": {
        "jsCode": "// Generar array de IDs desde startId hasta endId\nconst startId = $('Configurar Rango IDs').item.json.startId;\nconst endId = $('Configurar Rango IDs').item.json.endId;\n\nconst ids = [];\nfor (let i = startId; i <= endId; i++) {\n  ids.push({ documentId: i });\n}\n\nreturn ids;"
      },
      "id": "130ad660-01a4-42ef-a451-de8f1c36c28b",
      "name": "Generar Array IDs",
      "type": "n8n-nodes-base.code",
