    {
      "parameters": {
        "operation": "executeQuery",
        "query": "select   C.cuitid, c.transaccionid, pv.descripcion,c.nrocbte, c.cae,  f.Extension , t.EstadoTransaccion, c.Resultado, t.Fecha, convert(varchar,c.FechaCbte, 126) as fecha \nfrom comprobante c with(nolock) \ninner join transaccion t with(nolock) on (c.cuitid = t.cuitid and c.transaccionid = t.transaccionid)\ninner join puntodeventa pv with(nolock) on (c.cuitid = pv.cuitid and c.puntodeventaid = pv.puntodeventaid) \ninner join Formato f with(nolock) on (t.formatoid = f.formatoid)\nwhere   c.FechaCbte >=DATEADD(day, -3, GETDATE())  and Resultado='' and t.Fecha < DATEADD(MI, -30, GETDATE()) and EstadoTransaccion in (5,6,7)\nand not exists ( select 1 from Comprobante c2 where c.CuitId=c2.CuitId and c.tipocomprobanteid=c2.TipoComprobanteId and c.PuntoDeVentaId=c2.PuntoDeVentaId and c.NroCbte=c2.nrocbte and c.transaccionid<>c2.TransaccionId and c2.Resultado='A')\nand not exists ( select 1 from Comprobante c2 where c.CuitId=c2.CuitId and c.tipocomprobanteid=c2.TipoComprobanteId and c.PuntoDeVentaId=c2.PuntoDeVentaId and c.cae=c2.cae and c.transaccionid<>c2.TransaccionId and c2.Resultado='A');\n"
      },
