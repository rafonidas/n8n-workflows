    {
      "parameters": {
        "functionCode": "const updates = [\n  `UPDATE usuario SET mail = SUBSTRING(mail,1,CHARINDEX('@gmial.com', mail)-1)+'@gmail.com' WHERE mail LIKE '%@gmial.com'; SELECT @@ROWCOUNT AS filas;`,\n  `UPDATE usuario SET mail = SUBSTRING(mail,1,CHARINDEX('@hotamil.com', mail)-1)+'@hotmail.com' WHERE mail LIKE '%@hotamil.com'; SELECT @@ROWCOUNT AS filas;`,\n  `UPDATE usuario SET mail = SUBSTRING(mail,1,CHARINDEX('@hotmaill.com', mail)-1)+'@hotmail.com' WHERE mail LIKE '%@hotmaill.com'; SELECT @@ROWCOUNT AS filas;`,\n  `UPDATE usuario SET mail = SUBSTRING(mail,1,CHARINDEX('@hotmal.com', mail)-1)+'@hotmail.com' WHERE mail LIKE '%@hotmal.com'; SELECT @@ROWCOUNT AS filas;`,\n  `UPDATE usuario SET mail = SUBSTRING(mail,1,CHARINDEX('@homail.com', mail)-1)+'@hotmail.com' WHERE mail LIKE '%@homail.com'; SELECT @@ROWCOUNT AS filas;`,\n  `UPDATE usuario SET publicacioncomprobantes = 0 WHERE mail LIKE '%sincorreo%' AND Eliminado != 1 AND PublicacionComprobantes != 0; SELECT @@ROWCOUNT AS filas;`,\n  `UPDATE usuario\n   SET mail = REPLACE(REPLACE(mail, CHAR(9), ''), ' ', '')\n   WHERE mail LIKE '% %' OR mail LIKE '%' + CHAR(9) + '%';\n   SELECT @@ROWCOUNT AS filas;`\n];\n\nreturn updates.map(u => ({ json: { tipo: 'UPDATE', sentencia: u } }));;\n"
      },
