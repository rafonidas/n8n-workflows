      "parameters": {
        "jsCode": "// Recupera la sentencia y tipo del ítem original\nconst sentencia = $item(0).$json.sentencia || 'N/A';\nconst tipo = $item(0).$json.tipo || 'SELECT';\n\n// items[0].json debe tener { filasValidas: N }\nconst filas = (() => {\n  const j = items?.[0]?.json;\n  if (j == null) return 0;\n  const v = j.filasValidas ?? j.rowCount ?? (Array.isArray(j) ? j.length : 0);\n  return Number(v) || 0;\n})();\n\nreturn [{\n  json: {\n    tipo,\n    sentencia,\n    filasValidas: filas,\n    filas: filas\n  }\n}];"
      },
