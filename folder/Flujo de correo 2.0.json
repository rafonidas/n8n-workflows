      "parameters": {
        "functionCode": "const sd = this.getWorkflowStaticData('global');\nconst logs = sd.logs || [];\nconst selects = logs.filter(l => l.tipo === 'SELECT');\nconst updates = logs.filter(l => l.tipo === 'UPDATE');\nconst resumen = {\n  totalOperaciones: logs.length,\n  totalSelects: selects.length,\n  totalUpdates: updates.length,\n  filasSelects: selects.reduce((a, e) => a + (e.filas || 0), 0),\n  filasUpdates: updates.reduce((a, e) => a + (e.filas || 0), 0),\n  detalle: logs\n};\nreturn [{ json: resumen }];"
      },
      "id": "4a2ff4f6-fac2-4bb9-a498-2b18c5ff102e",
