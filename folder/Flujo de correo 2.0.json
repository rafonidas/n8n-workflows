        "functionCode": "const sd = this.getWorkflowStaticData('global');\nconst logs = sd.logs || [];\nconst selects = logs.filter(l => l.tipo === 'SELECT');\nconst filasSelectsValidas = selects.reduce((a, e) => a + (e.filas || 0), 0);\n\nreturn [{ json: { ejecutarUpdates: filasSelectsValidas > 0 } }];\n"
