    {
      "parameters": {
        "functionCode": "const selects = [\n  // GMAIL mal escrito\n  `SELECT COUNT(*) AS filasValidas\n   FROM usuario\n   WHERE mail LIKE '%@gmial.com';`,\n\n  // HOTMAIL mal escrito (variantes)\n  `SELECT COUNT(*) AS filasValidas\n   FROM usuario\n   WHERE mail LIKE '%@hotamil.com';`,\n\n  `SELECT COUNT(*) AS filasValidas\n   FROM usuario\n   WHERE mail LIKE '%@hotmaill.com';`,\n\n  `SELECT COUNT(*) AS filasValidas\n   FROM usuario\n   WHERE mail LIKE '%@hotmal.com';`,\n\n  `SELECT COUNT(*) AS filasValidas\n   FROM usuario\n   WHERE mail LIKE '%@homail.com';`,\n\n  // Usuarios sin correo y con restricciones\n  `SELECT COUNT(*) AS filasValidas\n   FROM usuario\n   WHERE mail LIKE '%sincorreo%'\n     AND Eliminado != 1\n     AND PublicacionComprobantes != 0;`,\n\n  // Correos con espacios o tabs\n  `SELECT COUNT(*) AS filasValidas\n   FROM usuario\n   WHERE mail LIKE '% %';`\n];\n\nreturn selects.map(s => ({\n  json: { tipo: 'SELECT', sentencia: s }\n}));"
      },
