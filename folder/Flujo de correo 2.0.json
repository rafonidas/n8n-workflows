    {
      "parameters": {
        "functionCode": "const sd = this.getWorkflowStaticData('global');\nif (!sd.logs) sd.logs = [];\n\nlet salida = [];\n\nif (!items || items.length === 0) {\n  // Iteración sin datos: crear ítem seguro\n  salida.push({\n    json: {\n      tipo: 'UPDATE',\n      sentencia: 'N/A',\n      filas: 0\n    }\n  });\n} else {\n  items.forEach((item, idx) => {\n    const json = item?.json || {};\n    const tipo = json.tipo || 'UPDATE';\n    const sentencia = json.sentencia || ($item(idx)?.$json?.sentencia) || 'N/A';\n    const filas = json.filasValidas ?? json.filas ?? 0;\n    const ts = new Date().toISOString();\n\n    sd.logs.push({ ts, tipo, sentencia, filas });\n\n    salida.push({ json: { tipo, sentencia, filas } });\n  });\n}\n\nreturn salida;\n"
      },
