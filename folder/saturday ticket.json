    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH LineaDeTiempoTickets AS (\n    -- Paso 1: Mapear la historia completa de cada ticket\n    SELECT \n        Id, \n        TicketId, \n        ComentId, \n        Tiempo,\n        -- Asignamos el número 1 al evento más antiguo de cada ticket, el 2 al siguiente, etc.\n        ROW_NUMBER() OVER(PARTITION BY TicketId ORDER BY Tiempo ASC) AS FilaCronologica\n    FROM dbo.VistasTickes\n)\n-- Paso 2: Filtrar sobre el estado depurado\nSELECT \n    Id, \n    TicketId, \n    ComentId, \n    Tiempo\nFROM LineaDeTiempoTickets\nWHERE FilaCronologica = 1 \n  AND DATEPART(dw, Tiempo) = 5 -- 4 = Miércoles (7 para Sábado)\n  AND CAST(Tiempo AS DATE) = CAST(GETDATE() AS DATE) -- Opcional: Asegura que sea el miércoles de HOY, no de hace 3 meses.\nORDER BY TicketId ASC;"
      },
