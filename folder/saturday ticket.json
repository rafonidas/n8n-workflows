    {
      "parameters": {
        "jsCode": "const config = $('Set Config').first().json;\nconst tickets = $input.first().json.tickets;\nconst count = tickets.length;\n\nconst fId  = config.campo_id;\nconst fCli = config.campo_cliente;\nconst fDes = config.campo_descripcion;\n\nlet body;\nif (count === 1) {\n  const t = tickets[0];\n  body = `• *ID:* ${t[fId]}\\n  *Cliente:* ${t[fCli]}\\n  *Descripción:* ${t[fDes]}`;\n} else {\n  body = tickets\n    .map(t => `• *#${t[fId]}* | ${t[fCli]} | ${t[fDes]}`)\n    .join('\\n');\n}\n\nconst header = count === 1\n  ? '🎫 *Nuevo ticket detectado*'\n  : `🎫 *${count} tickets detectados*`;\n\nreturn [{ json: {\n  message: `${header}\\n\\n${body}`,\n  count,\n  ticketIds: tickets.map(t => String(t[fId]))\n} }];"
      },
