        "jsCode": "const values = items.map(r => {\n  // Escapar comillas simples en razonSocial\n  const razonSocial = (r.json.RazonSocial || 'N/A').replace(/'/g, \"''\");\n\n  return `('${r.json.Pais}', '${r.json.Entorno}', ${r.json.Cliente}, '${razonSocial}', ${r.json.ano}, ${r.json.mes}, ${r.json.Cantidad})`;\n}).join(\",\\n\");\n\nreturn [{\n  json: {\n    query: `\n      MERGE ValoresxCliente AS target\n      USING (VALUES\n        ${values}\n      ) AS src (pais, entorno, cuitid, razonSocial, ano, mes, cantidad)\n      ON target.pais = src.pais\n         AND target.entorno = src.entorno\n         AND target.cuitid = src.cuitid\n         AND target.ano = src.ano\n         AND target.mes = src.mes\n      WHEN MATCHED THEN\n        UPDATE SET \n          target.razonSocial = src.razonSocial,\n          target.cantidad = src.cantidad\n      WHEN NOT MATCHED THEN\n        INSERT (pais, entorno, cuitid, razonSocial, ano, mes, cantidad)\n        VALUES (src.pais, src.entorno, src.cuitid, src.razonSocial, src.ano, src.mes, src.cantidad);\n    `\n  }\n}];\n\n\n"
      },
