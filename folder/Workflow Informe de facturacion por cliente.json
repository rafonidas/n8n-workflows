    {
      "parameters": {
        "jsCode": "const registros = $input.all();\nconst now = new Date();\nconst fechaHora = `${now.toISOString().slice(0,10)} ${now.toTimeString().slice(0,8)}`;\nconst mailSubject = `Actualización exitosa - Valores Mensuales`;\n\nconst mailBody = `\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <style>\n    body { font-family: Arial, sans-serif; background-color: #f6f7fb; margin:0; padding:0; }\n    .container { max-width: 700px; margin: 24px auto; background:#fff; padding: 24px; border-radius: 10px; \n                 box-shadow: 0 6px 16px rgba(0,0,0,0.08); }\n    .title { margin: 0 0 8px; color:#222; font-size: 20px; }\n    .msg { color:#333; margin: 8px 0 16px; }\n    .meta { color:#555; font-size: 13px; background:#f1f3f7; padding:10px; border-radius:8px; }\n    .brand { color:#921E30; font-weight:bold; margin-bottom: 6px; }\n    .footer { font-size:12px; color:#777; text-align:center; margin-top: 18px; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"brand\">APG Consulting Colombia</div>\n    <h1 class=\"title\">Actualización completada</h1>\n    <p class=\"msg\">La información de valores mensuales fue actualizada exitosamente.</p>\n    <div class=\"meta\">\n      <div><strong>Fecha y hora:</strong> ${fechaHora}</div>\n      <div><strong>Estado:</strong> OK</div>\n    </div>\n    <div class=\"footer\">\n      © ${new Date().getFullYear()} APG Consulting Colombia · Este mensaje fue generado automáticamente.\n    </div>\n  </div>\n</body>\n</html>\n`;\n\nreturn [{\n  json: {\n    mailSubject,\n    mailBody\n  }\n}];\n\n\n"
      },
