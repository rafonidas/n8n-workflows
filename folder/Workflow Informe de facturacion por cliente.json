    {
      "parameters": {
        "operation": "executeQuery",
        "query": "USE {{$json[\"db\"]}};\nSELECT \n    d.Pais,\n    d.Entorno,\n    C.CuitId,\n    CU.RazonSocial,\n    YEAR(T.Fecha) AS ano,\n    MONTH(T.Fecha) AS mes,\n    COUNT(C.CuitId) AS Emitidos\n    -- , SUM(C.ImporteTotal) AS MontoTotal  -- opcional\nFROM Comprobante AS C WITH(NOLOCK)\nINNER JOIN rol  \n    ON C.CuitId = Rol.CuitId \n   AND C.RolEmisorId = Rol.RolId \n   AND Rol.TipoRol = 1\nINNER JOIN Transaccion AS T \n    ON T.CuitId = C.CuitId \n   AND T.TransaccionId = C.TransaccionId\nINNER JOIN Cuit AS CU\n    ON C.CuitId = CU.CuitId\nCROSS APPLY (\n    SELECT \n        RIGHT(DB_NAME(), LEN(DB_NAME()) - CHARINDEX('_', DB_NAME())) AS Pais,\n        CASE \n            WHEN DB_NAME() LIKE '%[0-9]' \n                THEN 'APP' + RIGHT(DB_NAME(), 1)\n            ELSE 'APP'\n        END AS Entorno\n) d\nWHERE C.Resultado <> 'R'\n  AND YEAR(T.Fecha) = YEAR(GETDATE())   -- solo el año actual\nGROUP BY \n    d.Pais,\n    d.Entorno,\n    C.CuitId,\n    CU.RazonSocial,\n    YEAR(T.Fecha),\n    MONTH(T.Fecha)\nORDER BY \n    d.Pais,\n    d.Entorno,\n    ano,\n    mes,\n    C.CuitId;\n\n"
      },
