    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=SELECT n.email, u.rrhh, COUNT(*) as notif_count\nFROM notifications n\nLEFT JOIN dbo.NotiViga_userInfo u ON u.email = n.email\nWHERE n.status = 'SUCCESS'\n  AND n.notifiedAt >= DATEADD(day, -5, GETDATE())\nGROUP BY n.email, u.rrhh\nHAVING COUNT(*) >= 2"
      },
