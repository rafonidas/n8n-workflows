    {
      "parameters": {
        "jsCode": "// Registrar los IDs notificados. Clave: byDate → fecha → [ids]\n// Para migrar a n8n Data Tables: reemplazar por HTTP Request\n// POST /api/v1/tables/{tableId}/rows  body: { id, fecha }\n\nconst staticData = $getWorkflowStaticData('global');\nconst today = new Date().toISOString().split('T')[0];\nconst ids = $input.first().json.ticketIds;\n\nif (!staticData.byDate) staticData.byDate = {};\nif (!staticData.byDate[today]) staticData.byDate[today] = [];\n\nconst existing = new Set(staticData.byDate[today]);\nids.forEach(id => existing.add(id));\nstaticData.byDate[today] = [...existing];\n\n// Purgar registros con más de 7 días para no crecer indefinidamente\nconst cutoff = new Date();\ncutoff.setDate(cutoff.getDate() - 7);\nconst cutoffStr = cutoff.toISOString().split('T')[0];\nfor (const date of Object.keys(staticData.byDate)) {\n  if (date < cutoffStr) delete staticData.byDate[date];\n}\n\nreturn [{ json: {\n  fecha: today,\n  registrados: ids,\n  totalHoy: staticData.byDate[today].length\n} }];"
      },
