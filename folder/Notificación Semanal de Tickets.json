    {
      "parameters": {
        "jsCode": "const { message, ticketIds } = $input.first().json;\nconst cfg = $('Config1').first().json;\nconst phones = [cfg.phone_1, cfg.phone_2, cfg.phone_3, cfg.phone_4];\nreturn phones.map(phone => ({ json: { phone, message, ticketIds } }));"
      },
