    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    v.Id, \n    v.TicketId, \n    v.ComentId, \n    v.Tiempo\nFROM dbo.VistasTickes v\nWHERE \n    -- Filtramos PRIMERO por los registros de hoy. \n    -- Esto reduce drásticamente los datos a evaluar.\n    v.Tiempo >= DATEADD(hour, 3, CAST(CAST(GETDATE() AS DATE) AS DATETIME))\n    AND v.Tiempo < DATEADD(hour, 3, DATEADD(day, 1, CAST(CAST(GETDATE() AS DATE) AS DATETIME)))\n    -- SEGUNDO: Confirmamos que ese registro de hoy sea realmente el primer evento del ticket\n    AND v.Id = (\n        SELECT MIN(Id) \n        FROM dbo.VistasTickes v_min \n        WHERE v_min.TicketId = v.TicketId\n    )\nORDER BY v.TicketId ASC;"
      },
