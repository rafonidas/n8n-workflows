    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH TicketsOrdenados AS (\n    SELECT \n        Id, \n        TicketId, \n        ComentId, \n        Tiempo,\n        -- Esto numera las filas del 1 en adelante para cada TicketId, ordenando por el más antiguo primero\n        ROW_NUMBER() OVER(PARTITION BY TicketId ORDER BY Tiempo DESC) AS NumeroFila\n    FROM dbo.VistasTickes\n    WHERE DATEPART(dw, Tiempo) = 4 -- Filtro de día Sábado (7)\n      AND Tiempo >= CAST(GETDATE() AS DATE) -- Solo los de hoy\n)\n-- Extraemos solo la fila 1 (el primer registro cronológico) de cada ticket\nSELECT Id, TicketId, ComentId, Tiempo\nFROM TicketsOrdenados\nWHERE NumeroFila = 1;"
      },
      "type": "n8n-nodes-base.microsoftSql",
      "typeVersion": 1.1,
      "position": [
        -48,
        -192
      ],
      "id": "a4cbb51a-5f22-4e5e-b795-2386ffdd0965",
      "name": "Microsoft SQL",
