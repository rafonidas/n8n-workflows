        "jsCode": "// Lee los IDs notificados HOY desde el registro interno del workflow.\n// Para migrar a n8n Data Tables: reemplazar por HTTP Request a la API de n8n\n// GET /api/v1/tables/{tableId}/rows?filter=fecha:eq:{today}\n\nconst staticData = $getWorkflowStaticData('global');\nconst today = new Date().toISOString().split('T')[0];\nconst idField = 47777;\nconst todayIds = (staticData.byDate || {})[today] || [];\n\n// Retornar item dummy si no hay IDs previos (evita input vacío en Compare Datasets)\nif (todayIds.length === 0) {\n  return [{ json: { [idField]: '__NONE__' } }];\n}\nreturn todayIds.map(id => ({ json: { [idField]: id } }));"
