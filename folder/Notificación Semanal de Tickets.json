  "name": "Notificación Semanal de Tickets",
  "nodes": [
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH LineaDeTiempoTickets AS (\n    -- Paso 1: Numerar todos los eventos históricos por ticket\n    SELECT \n        Id, \n        TicketId, \n        ComentId, \n        Tiempo,\n        -- Ordenamos ASCENDENTE. El menor tiempo (creación) recibe el 1.\n        -- Agregamos \"Id ASC\" por si hay dos eventos en el mismo milisegundo.\n        ROW_NUMBER() OVER(PARTITION BY TicketId ORDER BY Id ASC, TicketId ASC) AS FilaCronologica\n    FROM dbo.VistasTickes\n)\n-- Paso 2: Filtrar para quedarnos SOLO con las creaciones que ocurrieron \"Hoy\" (local)\nSELECT \n    Id, \n    TicketId, \n    ComentId, \n    Tiempo\nFROM LineaDeTiempoTickets\nWHERE FilaCronologica = 1 -- Exigimos que sea el primer registro absoluto del ticket (Creación)\n  \n  -- Exigimos que el tiempo UTC de esa creación esté dentro de nuestro \"Hoy\"\n  AND Tiempo >= DATEADD(hour, 3, CAST(CAST(GETDATE() AS DATE) AS DATETIME))\n  AND Tiempo < DATEADD(hour, 3, DATEADD(day, 1, CAST(CAST(GETDATE() AS DATE) AS DATETIME)))\nORDER BY TicketId ASC;"
      },
