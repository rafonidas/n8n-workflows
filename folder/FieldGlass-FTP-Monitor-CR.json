    {
      "parameters": {
        "jsCode": "const now = Date.now();\nconst ONE_HOUR_MS = 60 * 60 * 1000;\n\nconst oldFiles = $input.all()\n  .filter(item => {\n    const f = item.json;\n    // solo archivos sueltos (no directorios)\n    return f.type === '-' && (now - f.modifyTime) > ONE_HOUR_MS;\n  })\n  .sort((a, b) => a.json.modifyTime - b.json.modifyTime);\n\nif (oldFiles.length === 0) return [];\n\nconst fileRows = oldFiles.map(item => {\n  const f = item.json;\n  const date = new Date(f.modifyTime).toLocaleString('es-CR', { timeZone: 'America/Costa_Rica' });\n  const ageMin = Math.round((now - f.modifyTime) / 60000);\n  return `<li><b>${f.name}</b> — ${date} (${ageMin} min)</li>`;\n}).join('');\n\nreturn [{\n  json: {\n    count: oldFiles.length,\n    fileRows\n  }\n}];"
      },
